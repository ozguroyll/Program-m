<UserControl x:Class="StokMuhasebeLojistik.Views.LogisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StokMuhasebeLojistik.Views">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Lojistik Yönetimi" Style="{StaticResource HeaderTextStyle}"/>
            <Button Content="Yeni Araç" 
                   Style="{StaticResource ModernButtonStyle}"
                   Command="{Binding StartAddVehicleCommand}"
                   Margin="20,0,10,0"/>
            <Button Content="Yeni Sefer" 
                   Style="{StaticResource ModernButtonStyle}"
                   Command="{Binding StartAddTripCommand}"/>
        </StackPanel>
        
        <TabControl Grid.Row="1">
            <TabItem Header="Araçlar">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Araç Filosu" Style="{StaticResource SubHeaderTextStyle}"/>
                            <DataGrid ItemsSource="{Binding Vehicles}" 
                                     SelectedItem="{Binding SelectedVehicle}"
                                     Style="{StaticResource ModernDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Plaka" Binding="{Binding PlateNumber}" Width="120"/>
                                    <DataGridTextColumn Header="Marka" Binding="{Binding Brand}" Width="100"/>
                                    <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="100"/>
                                    <DataGridTextColumn Header="Yıl" Binding="{Binding Year}" Width="80"/>
                                    <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="100"/>
                                    <DataGridTextColumn Header="Sahiplik" Binding="{Binding Ownership}" Width="120"/>
                                    <DataGridTextColumn Header="Şoför" Binding="{Binding Driver.FullName}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" 
                           Visibility="{Binding IsAddingVehicle, Converter={x:Static local:BooleanToVisibilityConverter.Instance}}">
                        <StackPanel>
                            <TextBlock Text="Yeni Araç" Style="{StaticResource SubHeaderTextStyle}"/>
                            
                            <TextBlock Text="Plaka:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewVehicle.PlateNumber}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Marka:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewVehicle.Brand}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Model:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewVehicle.Model}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Yıl:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewVehicle.Year}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Araç Tipi:" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox SelectedValue="{Binding NewVehicle.Type}" Style="{StaticResource ModernComboBoxStyle}">
                                <ComboBoxItem Content="Çekici" Tag="Cekici"/>
                                <ComboBoxItem Content="Römork" Tag="Romork"/>
                                <ComboBoxItem Content="Kamyon" Tag="Kamyon"/>
                                <ComboBoxItem Content="Diğer" Tag="Diger"/>
                            </ComboBox>
                            
                            <TextBlock Text="Sahiplik:" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox SelectedValue="{Binding NewVehicle.Ownership}" Style="{StaticResource ModernComboBoxStyle}">
                                <ComboBoxItem Content="Şirket Aracı" Tag="SirketAracı"/>
                                <ComboBoxItem Content="Kiralık Araç" Tag="KiralikArac"/>
                                <ComboBoxItem Content="Ortak Araç" Tag="OrtakArac"/>
                            </ComboBox>
                            
                            <TextBlock Text="Şoför:" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox ItemsSource="{Binding Drivers}" 
                                     SelectedValue="{Binding NewVehicle.DriverId}"
                                     DisplayMemberPath="FullName"
                                     SelectedValuePath="Id"
                                     Style="{StaticResource ModernComboBoxStyle}"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <Button Content="Kaydet" 
                                       Style="{StaticResource ModernButtonStyle}"
                                       Command="{Binding SaveVehicleCommand}"/>
                                <Button Content="İptal" 
                                       Style="{StaticResource SecondaryButtonStyle}"
                                       Command="{Binding CancelAddVehicleCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            
            <TabItem Header="Seferler">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Aktif Seferler" Style="{StaticResource SubHeaderTextStyle}"/>
                            <DataGrid ItemsSource="{Binding Trips}" 
                                     SelectedItem="{Binding SelectedTrip}"
                                     Style="{StaticResource ModernDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Sefer No" Binding="{Binding TripNumber}" Width="120"/>
                                    <DataGridTextColumn Header="Müşteri" Binding="{Binding Customer.Name}" Width="150"/>
                                    <DataGridTextColumn Header="Araç" Binding="{Binding Vehicle.PlateNumber}" Width="100"/>
                                    <DataGridTextColumn Header="Güzergah" Binding="{Binding Origin}" Width="100"/>
                                    <DataGridTextColumn Header="Varış" Binding="{Binding Destination}" Width="100"/>
                                    <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="120"/>
                                    <DataGridTextColumn Header="Nakliye Bedeli" Binding="{Binding TransportPrice, StringFormat='{}{0:C}'}" Width="120"/>
                                    <DataGridTemplateColumn Header="İşlemler" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Durum Güncelle" 
                                                       Style="{StaticResource ModernButtonStyle}"
                                                       Command="{Binding DataContext.UpdateTripStatusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" 
                           Visibility="{Binding IsAddingTrip, Converter={x:Static local:BooleanToVisibilityConverter.Instance}}">
                        <StackPanel>
                            <TextBlock Text="Yeni Sefer" Style="{StaticResource SubHeaderTextStyle}"/>
                            
                            <TextBlock Text="Müşteri:" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox ItemsSource="{Binding Customers}" 
                                     SelectedValue="{Binding NewTrip.CustomerId}"
                                     DisplayMemberPath="Name"
                                     SelectedValuePath="Id"
                                     Style="{StaticResource ModernComboBoxStyle}"/>
                            
                            <TextBlock Text="Araç:" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox ItemsSource="{Binding Vehicles}" 
                                     SelectedValue="{Binding NewTrip.VehicleId}"
                                     DisplayMemberPath="PlateNumber"
                                     SelectedValuePath="Id"
                                     Style="{StaticResource ModernComboBoxStyle}"/>
                            
                            <TextBlock Text="Çıkış:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewTrip.Origin}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Varış:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewTrip.Destination}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Ürün:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewTrip.ProductName}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Miktar:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewTrip.Quantity}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Nakliye Bedeli:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewTrip.TransportPrice}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <Button Content="Kaydet" 
                                       Style="{StaticResource ModernButtonStyle}"
                                       Command="{Binding SaveTripCommand}"/>
                                <Button Content="İptal" 
                                       Style="{StaticResource SecondaryButtonStyle}"
                                       Command="{Binding CancelAddTripCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
