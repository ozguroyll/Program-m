<UserControl x:Class="StokMuhasebeLojistik.Views.StockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StokMuhasebeLojistik.Views">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Stok Yönetimi" Style="{StaticResource HeaderTextStyle}"/>
            <Button Content="Yeni Stok Ekle" 
                   Style="{StaticResource ModernButtonStyle}"
                   Command="{Binding StartAddStockCommand}"
                   Margin="20,0,0,0"/>
        </StackPanel>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Stok Kalemleri" Style="{StaticResource SubHeaderTextStyle}"/>
                    <DataGrid ItemsSource="{Binding StockItems}" 
                             SelectedItem="{Binding SelectedStockItem}"
                             Style="{StaticResource ModernDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="100"/>
                            <DataGridTextColumn Header="Ürün Adı" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Miktar" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Birim" Binding="{Binding Unit}" Width="80"/>
                            <DataGridTextColumn Header="Fiyat" Binding="{Binding UnitPrice, StringFormat='{}{0:C}'}" Width="100"/>
                            <DataGridTextColumn Header="Para Birimi" Binding="{Binding Currency}" Width="80"/>
                            <DataGridTextColumn Header="Müşteri" Binding="{Binding Customer.Name}" Width="150"/>
                            <DataGridTemplateColumn Header="İşlemler" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Hareket" 
                                                   Style="{StaticResource ModernButtonStyle}"
                                                   Command="{Binding DataContext.AddStockMovementCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}"
                                                   Margin="2"/>
                                            <Button Content="Sil" 
                                                   Style="{StaticResource DangerButtonStyle}"
                                                   Command="{Binding DataContext.DeleteStockCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}"
                                                   Margin="2"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" 
                   Visibility="{Binding IsAddingStock, Converter={x:Static local:BooleanToVisibilityConverter.Instance}}">
                <StackPanel>
                    <TextBlock Text="Yeni Stok Kalemi" Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <TextBlock Text="Ürün Adı:" Style="{StaticResource LabelTextStyle}"/>
                    <TextBox Text="{Binding NewStockItem.Name}" Style="{StaticResource ModernTextBoxStyle}"/>
                    
                    <TextBlock Text="Kod:" Style="{StaticResource LabelTextStyle}"/>
                    <TextBox Text="{Binding NewStockItem.Code}" Style="{StaticResource ModernTextBoxStyle}"/>
                    
                    <TextBlock Text="Miktar:" Style="{StaticResource LabelTextStyle}"/>
                    <TextBox Text="{Binding NewStockItem.Quantity}" Style="{StaticResource ModernTextBoxStyle}"/>
                    
                    <TextBlock Text="Birim:" Style="{StaticResource LabelTextStyle}"/>
                    <TextBox Text="{Binding NewStockItem.Unit}" Style="{StaticResource ModernTextBoxStyle}"/>
                    
                    <TextBlock Text="Birim Fiyat:" Style="{StaticResource LabelTextStyle}"/>
                    <TextBox Text="{Binding NewStockItem.UnitPrice}" Style="{StaticResource ModernTextBoxStyle}"/>
                    
                    <TextBlock Text="Para Birimi:" Style="{StaticResource LabelTextStyle}"/>
                    <ComboBox SelectedValue="{Binding NewStockItem.Currency}" Style="{StaticResource ModernComboBoxStyle}">
                        <ComboBoxItem Content="TL" Tag="TL"/>
                        <ComboBoxItem Content="USD" Tag="USD"/>
                        <ComboBoxItem Content="EUR" Tag="EUR"/>
                    </ComboBox>
                    
                    <TextBlock Text="Müşteri:" Style="{StaticResource LabelTextStyle}"/>
                    <ComboBox ItemsSource="{Binding Customers}" 
                             SelectedValue="{Binding NewStockItem.CustomerId}"
                             DisplayMemberPath="Name"
                             SelectedValuePath="Id"
                             Style="{StaticResource ModernComboBoxStyle}"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="Kaydet" 
                               Style="{StaticResource ModernButtonStyle}"
                               Command="{Binding SaveStockCommand}"/>
                        <Button Content="İptal" 
                               Style="{StaticResource SecondaryButtonStyle}"
                               Command="{Binding CancelAddStockCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
