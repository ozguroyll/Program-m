<UserControl x:Class="StokMuhasebeLojistik.Views.AccountingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StokMuhasebeLojistik.Views">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Muhasebe Yönetimi" Style="{StaticResource HeaderTextStyle}"/>
            <Button Content="Yeni Cari Hesap" 
                   Style="{StaticResource ModernButtonStyle}"
                   Command="{Binding StartAddCurrentAccountCommand}"
                   Margin="20,0,10,0"/>
            <Button Content="Yeni İşlem" 
                   Style="{StaticResource ModernButtonStyle}"
                   Command="{Binding StartAddTransactionCommand}"/>
        </StackPanel>
        
        <TabControl Grid.Row="1">
            <TabItem Header="Cari Hesaplar">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Cari Hesaplar" Style="{StaticResource SubHeaderTextStyle}"/>
                            <DataGrid ItemsSource="{Binding CurrentAccounts}" 
                                     SelectedItem="{Binding SelectedCurrentAccount}"
                                     Style="{StaticResource ModernDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="100"/>
                                    <DataGridTextColumn Header="Adı" Binding="{Binding Name}" Width="200"/>
                                    <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="100"/>
                                    <DataGridTextColumn Header="TL Bakiye" Binding="{Binding BalanceTL, StringFormat='{}{0:C}'}" Width="120"/>
                                    <DataGridTextColumn Header="USD Bakiye" Binding="{Binding BalanceUSD, StringFormat='${0:F2}'}" Width="120"/>
                                    <DataGridTextColumn Header="EUR Bakiye" Binding="{Binding BalanceEUR, StringFormat='€{0:F2}'}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" 
                           Visibility="{Binding IsAddingCurrentAccount, Converter={x:Static local:BooleanToVisibilityConverter.Instance}}">
                        <StackPanel>
                            <TextBlock Text="Yeni Cari Hesap" Style="{StaticResource SubHeaderTextStyle}"/>
                            
                            <TextBlock Text="Adı:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewCurrentAccount.Name}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Kod:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewCurrentAccount.Code}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Vergi No:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewCurrentAccount.TaxNumber}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Tip:" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox SelectedValue="{Binding NewCurrentAccount.Type}" Style="{StaticResource ModernComboBoxStyle}">
                                <ComboBoxItem Content="Müşteri" Tag="Musteri"/>
                                <ComboBoxItem Content="Tedarikçi" Tag="Tedarikci"/>
                                <ComboBoxItem Content="Nakliyeci" Tag="Nakliyeci"/>
                                <ComboBoxItem Content="Banka" Tag="Banka"/>
                                <ComboBoxItem Content="Diğer" Tag="Diger"/>
                            </ComboBox>
                            
                            <TextBlock Text="Adres:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewCurrentAccount.Address}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Telefon:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewCurrentAccount.Phone}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <Button Content="Kaydet" 
                                       Style="{StaticResource ModernButtonStyle}"
                                       Command="{Binding SaveCurrentAccountCommand}"/>
                                <Button Content="İptal" 
                                       Style="{StaticResource SecondaryButtonStyle}"
                                       Command="{Binding CancelAddCurrentAccountCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            
            <TabItem Header="Mali İşlemler">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Mali İşlemler" Style="{StaticResource SubHeaderTextStyle}"/>
                            <DataGrid ItemsSource="{Binding Transactions}" 
                                     Style="{StaticResource ModernDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="İşlem No" Binding="{Binding TransactionNumber}" Width="120"/>
                                    <DataGridTextColumn Header="Tarih" Binding="{Binding TransactionDate, StringFormat='{}{0:dd.MM.yyyy}'}" Width="100"/>
                                    <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="100"/>
                                    <DataGridTextColumn Header="Tutar" Binding="{Binding Amount, StringFormat='{}{0:C}'}" Width="120"/>
                                    <DataGridTextColumn Header="Para Birimi" Binding="{Binding Currency}" Width="80"/>
                                    <DataGridTextColumn Header="Cari" Binding="{Binding CurrentAccount.Name}" Width="150"/>
                                    <DataGridTextColumn Header="Açıklama" Binding="{Binding Description}" Width="200"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" 
                           Visibility="{Binding IsAddingTransaction, Converter={x:Static local:BooleanToVisibilityConverter.Instance}}">
                        <StackPanel>
                            <TextBlock Text="Yeni Mali İşlem" Style="{StaticResource SubHeaderTextStyle}"/>
                            
                            <TextBlock Text="İşlem Tipi:" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox SelectedValue="{Binding NewTransaction.Type}" Style="{StaticResource ModernComboBoxStyle}">
                                <ComboBoxItem Content="Tahsilat" Tag="Tahsilat"/>
                                <ComboBoxItem Content="Ödeme" Tag="Odeme"/>
                                <ComboBoxItem Content="Virman" Tag="Virman"/>
                            </ComboBox>
                            
                            <TextBlock Text="Cari Hesap:" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox ItemsSource="{Binding CurrentAccounts}" 
                                     SelectedValue="{Binding NewTransaction.CurrentAccountId}"
                                     DisplayMemberPath="Name"
                                     SelectedValuePath="Id"
                                     Style="{StaticResource ModernComboBoxStyle}"/>
                            
                            <TextBlock Text="Tutar:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewTransaction.Amount}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <TextBlock Text="Para Birimi:" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox SelectedValue="{Binding NewTransaction.Currency}" Style="{StaticResource ModernComboBoxStyle}">
                                <ComboBoxItem Content="TL" Tag="TL"/>
                                <ComboBoxItem Content="USD" Tag="USD"/>
                                <ComboBoxItem Content="EUR" Tag="EUR"/>
                            </ComboBox>
                            
                            <TextBlock Text="Ödeme Yöntemi:" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox SelectedValue="{Binding NewTransaction.PaymentMethod}" Style="{StaticResource ModernComboBoxStyle}">
                                <ComboBoxItem Content="Nakit" Tag="Nakit"/>
                                <ComboBoxItem Content="Banka" Tag="Banka"/>
                                <ComboBoxItem Content="Çek" Tag="Cek"/>
                                <ComboBoxItem Content="Senet" Tag="Senet"/>
                                <ComboBoxItem Content="Swift" Tag="Swift"/>
                            </ComboBox>
                            
                            <TextBlock Text="Açıklama:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Text="{Binding NewTransaction.Description}" Style="{StaticResource ModernTextBoxStyle}"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <Button Content="Kaydet" 
                                       Style="{StaticResource ModernButtonStyle}"
                                       Command="{Binding SaveTransactionCommand}"/>
                                <Button Content="İptal" 
                                       Style="{StaticResource SecondaryButtonStyle}"
                                       Command="{Binding CancelAddTransactionCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
